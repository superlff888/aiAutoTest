# ============= 应用配置 =============
APP_NAME=fastapi-oss-mysql-backend
APP_ENV=dev                       # dev / staging / prod
APP_VERSION=0.1.0
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_TIMEZONE=Asia/Shanghai

# ============= 安全配置 =============
# 生产环境必须用 openssl rand -hex 32 生成
SECRET_KEY=change-me-to-a-random-32-bytes-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============= MySQL 数据库 =============
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123456
DB_NAME=fastapi_demo
DB_CHARSET=utf8mb4
DB_ECHO=False                     # 是否打印 SQL
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ============= Redis 缓存 =============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# ============= 阿里云 OSS =============
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name
OSS_CDN_DOMAIN=                    # CDN 域名（可选，加速访问）
OSS_EXPIRE_SECONDS=3600
OSS_MAX_FILE_SIZE_MB=100
OSS_TEMP_DIR=./temp

# ============= 日志 =============
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING / ERROR
LOG_ROTATION=100 MB
LOG_RETENTION=30 days
LOG_DIR=./logs

# ============= 限流 =============
RATE_LIMIT_DEFAULT=100/minute

# ============= CORS =============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=True
CORS_METHODS=*
CORS_HEADERS=*

# ============= 监控 =============
SENTRY_DSN=                       # 留空则不启用
PROMETHEUS_ENABLED=True
OTEL_ENABLED=False
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
