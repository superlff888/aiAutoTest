<node id="认证方式">
  <data key="d0">认证方式</data>
  <data key="d1">concept</data>
  <data key="d2">认证方式是API安全机制，说明所有需要认证的接口需要在请求头中添加特定的认证信息。</data>
  <data key="d3">chunk-315944f454bfdc133f2b833baf92761d</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779718621</data>
  <data key="d6"></data>
</node>
<node id="Authorization Bearer Token">
  <data key="d0">Authorization Bearer Token</data>
  <data key="d1">data</data>
  <data key="d2">Authorization Bearer Token是一种JWT令牌，用于API接口的身份认证。</data>
  <data key="d3">chunk-315944f454bfdc133f2b833baf92761d</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779718624</data>
  <data key="d6"></data>
</node>
