  <data key="d0">商品列表接口</data>
  <data key="d1">method</data>
  <data key="d2">商品列表接口是GET /api/products API端点，用于获取商品列表，支持分类ID、关键词、价格区间、排序、分页等查询参数。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719057</data>
  <data key="d6"></data>
</node>
<node id="商品详情接口">
  <data key="d0">商品详情接口</data>
  <data key="d1">method</data>
  <data key="d2">商品详情接口是GET /api/products/{productId} API端点，用于获取特定商品的详细信息。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719057</data>
  <data key="d6"></data>
</node>
<node id="商品收藏接口">
  <data key="d0">商品收藏接口</data>
  <data key="d1">method</data>
  <data key="d2">商品收藏接口包括POST收藏、DELETE取消收藏、GET收藏列表三个API端点，用于管理用户对商品的收藏操作。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719057</data>
  <data key="d6"></data>
</node>
<node id="购物车接口">
  <data key="d0">购物车接口</data>
  <data key="d1">method</data>
  <data key="d2">购物车接口包括加入购物车、获取购物车列表、修改购物车商品、删除购物车商品、批量删除等API端点。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719057</data>
  <data key="d6"></data>
</node>
