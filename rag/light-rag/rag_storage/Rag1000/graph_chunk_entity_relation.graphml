  <data key="d0">分类查询参数</data>
  <data key="d1">data</data>
  <data key="d2">分类查询参数是用于筛选商品的categoryId参数，属于可选查询条件。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719057</data>
  <data key="d6"></data>
</node>
<node id="关键词搜索参数">
  <data key="d0">关键词搜索参数</data>
  <data key="d1">data</data>
  <data key="d2">关键词搜索参数是用于按关键词搜索商品的keyword参数，属于可选查询条件。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
</node>
<node id="价格区间参数">
  <data key="d0">价格区间参数</data>
  <data key="d1">data</data>
  <data key="d2">价格区间参数包括minPrice和maxPrice，用于筛选指定价格范围内的商品。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
</node>
<node id="排序参数">
  <data key="d0">排序参数</data>
  <data key="d1">data</data>
  <data key="d2">排序参数是用于指定商品排序方式的sort参数，如price_asc表示按价格升序排列。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
</node>
<node id="库存数据">
  <data key="d0">库存数据</data>
  <data key="d1">data</data>
  <data key="d2">库存数据表示商品的库存数量，是商品的重要属性，智能手机库存为50件。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
</node>
<node id="购物车数量">
  <data key="d0">购物车数量</data>
  <data key="d1">data</data>
  <data key="d2">购物车数量表示用户添加到购物车的商品数量，是购物车的基本属性。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
</node>
<node id="商品评分">
  <data key="d0">商品评分</data>
  <data key="d1">data</data>
  <data key="d2">商品评分是用户对商品的评价指标，智能手机评分为4.5分。</data>
  <data key="d3">chunk-8302692fb8bb5ca27290b44a3fedf7f2</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779719065</data>
  <data key="d6"></data>
