  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="时间范围">
  <data key="d0">时间范围</data>
  <data key="d1">data</data>
  <data key="d2">时间范围是展示时间段字段的数据类型标识，表示展示时间由开始时间到结束时间组成。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="首页">
  <data key="d0">首页</data>
  <data key="d1">location</data>
  <data key="d2">首页是平台系统中的主页面，用于展示轮播图、推荐商品和公告栏等内容。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="活动页">
  <data key="d0">活动页</data>
  <data key="d1">concept</data>
  <data key="d2">活动页是点击轮播图跳转的目标页面类型之一，用于展示促销活动内容。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="商品页">
  <data key="d0">商品页</data>
  <data key="d1">concept</data>
  <data key="d2">商品页是点击轮播图跳转的目标页面类型之一，用于展示商品详细信息。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="下架商品">
  <data key="d0">下架商品</data>
  <data key="d1">concept</data>
  <data key="d2">下架商品是指状态为下架的商品，不可被绑定到推荐位进行展示。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="展示顺序">
  <data key="d0">展示顺序</data>
  <data key="d1">concept</data>
  <data key="d2">展示顺序是指多条公告或多个内容项在页面上的排列次序，由权重或排序字段控制。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="定时生效">
  <data key="d0">定时生效</data>
  <data key="d1">concept</data>
  <data key="d2">定时生效是指设置公告在指定时间自动开始展示的功能。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="定时下线">
  <data key="d0">定时下线</data>
  <data key="d1">concept</data>
  <data key="d2">定时下线是指设置公告在指定时间自动停止展示的功能。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="超链接">
  <data key="d0">超链接</data>
  <data key="d1">concept</data>
  <data key="d2">超链接是公告内容支持的富文本格式之一，可跳转到详情页。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="简单富文本格式">
  <data key="d0">简单富文本格式</data>
  <data key="d1">concept</data>
  <data key="d2">简单富文本格式是公告内容支持的文本格式，包含基本的文字排版和超链接功能。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670442</data>
  <data key="d6"></data>
</node>
<node id="详情页">
  <data key="d0">详情页</data>
  <data key="d1">concept</data>
  <data key="d2">详情页是公告内容中超链接跳转的目标页面，用于展示完整的内容信息。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="手机号绑定功能">
  <data key="d0">手机号绑定功能</data>
  <data key="d1">concept</data>
  <data key="d2">手机号绑定功能是系统中的一个业务规则，用于将手机号与用户账号进行绑定，一个手机号只能绑定一个账号。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="收货地址管理功能">
  <data key="d0">收货地址管理功能</data>
  <data key="d1">method</data>
  <data key="d2">收货地址管理功能允许用户新增、编辑、删除收货地址，并可设置默认地址用于下单，每个用户最多绑定5个地址。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="获取验证码功能">
  <data key="d0">获取验证码功能</data>
  <data key="d1">method</data>
  <data key="d2">获取验证码功能用于向用户手机号或邮箱发送验证码进行身份验证，同一手机号或邮箱每分钟限发1次，每小时最多5次。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="首页商品展示功能">
  <data key="d0">首页商品展示功能</data>
  <data key="d1">method</data>
  <data key="d2">首页商品展示功能在用户进入商城首页时展示轮播图、分类列表、推荐商品等最具吸引力的内容。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="分类列表">
  <data key="d0">分类列表</data>
  <data key="d1">content</data>
  <data key="d2">分类列表是首页展示的商品分类入口，最多显示6个主分类。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="商品列表浏览功能">
  <data key="d0">商品列表浏览功能</data>
  <data key="d1">method</data>
  <data key="d2">商品列表浏览功能支持用户按分类、价格区间、销量、人气等维度进行筛选、排序与分页浏览，每页默认显示20条记录。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="商品详情页功能">
  <data key="d0">商品详情页功能</data>
  <data key="d1">method</data>
  <data key="d2">商品详情页功能展示商品的完整信息，包括图片、价格、库存、参数、用户评论、售后说明等，帮助用户做出购买决策。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670456</data>
  <data key="d6"></data>
</node>
<node id="商品收藏功能">
  <data key="d0">商品收藏功能</data>
  <data key="d1">method</data>
  <data key="d2">商品收藏功能允许登录用户收藏感兴趣的商品，便于后续查看与复购。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="购物车功能">
  <data key="d0">购物车功能</data>
  <data key="d1">method</data>
  <data key="d2">购物车功能是商品详情页提供的功能，允许用户将商品加入购物车以便后续购买。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="立即购买功能">
  <data key="d0">立即购买功能</data>
  <data key="d1">method</data>
  <data key="d2">立即购买功能是商品详情页提供的功能，允许用户直接购买商品。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="商品主图">
  <data key="d0">商品主图</data>
  <data key="d1">content</data>
  <data key="d2">商品主图是商品详情页展示的商品图片，最多展示5张，支持左右滑动。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="商品库存">
  <data key="d0">商品库存</data>
  <data key="d1">data</data>
  <data key="d2">商品库存是商品详情页展示的商品库存数量，显示商品的可用数量。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="商品参数">
  <data key="d0">商品参数</data>
  <data key="d1">data</data>
  <data key="d2">商品参数是商品详情页展示的商品规格参数信息，帮助用户了解商品详情。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
<node id="售后说明">
  <data key="d0">售后说明</data>
  <data key="d1">content</data>
  <data key="d2">售后说明是商品详情页底部固定显示的售后退换货说明信息。</data>
  <data key="d3">chunk-6971ea2199ce98c9bf6210f674f5d1e5</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670467</data>
  <data key="d6"></data>
</node>
