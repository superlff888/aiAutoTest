  <data key="d2">系统管理功能界面，用于配置审核模式等系统参数。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670354</data>
  <data key="d6"></data>
</node>
<node id="审核模式">
  <data key="d0">审核模式</data>
  <data key="d1">concept</data>
  <data key="d2">内容审核的处理方式配置，支持全自动通过、人工审核、混合模式三种类型。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670354</data>
  <data key="d6"></data>
</node>
<node id="全自动通过">
  <data key="d0">全自动通过</data>
  <data key="d1">concept</data>
  <data key="d2">审核模式的一种，内容自动发布无需人工审核。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670354</data>
  <data key="d6"></data>
</node>
<node id="人工审核">
  <data key="d0">人工审核</data>
  <data key="d1">concept</data>
  <data key="d2">审核模式的一种，所有内容需由人工进行审核处理。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="混合模式">
  <data key="d0">混合模式</data>
  <data key="d1">concept</data>
  <data key="d2">审核模式的一种，结合自动和人工方式进行内容审核。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="操作权限管理">
  <data key="d0">操作权限管理</data>
  <data key="d1">concept</data>
  <data key="d2">系统管理功能，确保审核、删除、封禁等敏感操作仅限特定角色执行。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="正则过滤">
  <data key="d0">正则过滤</data>
  <data key="d1">method</data>
  <data key="d2">使用正则表达式对内容进行自动化过滤的方法。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="封禁">
  <data key="d0">封禁</data>
  <data key="d1">method</data>
  <data key="d2">管理员对严重违规用户执行的禁止访问操作。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="内容管理员">
  <data key="d0">内容管理员</data>
  <data key="d1">person</data>
  <data key="d2">负责内容审核、删除、封禁等操作的特殊管理员角色。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670368</data>
  <data key="d6"></data>
</node>
<node id="状态变更日志">
  <data key="d0">状态变更日志</data>
  <data key="d1">data</data>
  <data key="d2">记录评论状态变更的日志信息，包含操作人、操作时间、来源入口。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670371</data>
  <data key="d6"></data>
</node>
<node id="审核记录">
  <data key="d0">审核记录</data>
  <data key="d1">data</data>
  <data key="d2">记录内容审核操作的数据，包含操作人、时间、备注信息。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670371</data>
  <data key="d6"></data>
</node>
<node id="备注">
  <data key="d0">备注</data>
  <data key="d1">data</data>
  <data key="d2">审核或处理操作时添加的说明文字。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="展示时间段">
  <data key="d0">展示时间段</data>
  <data key="d1">data</data>
  <data key="d2">展示时间段字段用于设置内容的展示时间范围，包括开始时间和结束时间。&lt;SEP&gt;轮播图配置的时间范围字段，用于控制轮播图的展示时间。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="排序权重">
  <data key="d0">排序权重</data>
  <data key="d1">data</data>
  <data key="d2">排序权重字段为数字类型，用于控制内容的展示顺序，数值越小越靠前。&lt;SEP&gt;轮播图配置的数字字段，数值越小排序越靠前。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="跳转链接">
  <data key="d0">跳转链接</data>
  <data key="d1">data</data>
  <data key="d2">跳转链接字段用于设置点击轮播图后跳转的活动页或商品页URL，需进行合法性校验。&lt;SEP&gt;轮播图点击后跳转的目标地址，可以是活动页或商品页。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="标题">
  <data key="d0">标题</data>
  <data key="d1">data</data>
  <data key="d2">标题字段用于设置轮播图的展示标题，为可选字段，默认不展示。&lt;SEP&gt;轮播图的文字标题字段，可选配置，默认不展示。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="图片地址">
  <data key="d0">图片地址</data>
  <data key="d1">data</data>
  <data key="d2">图片地址字段用于存储轮播图的URL地址，支持CDN加速。&lt;SEP&gt;轮播图所使用的图片资源链接，支持CDN加速。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="上架状态">
  <data key="d0">上架状态</data>
  <data key="d1">concept</data>
  <data key="d2">内容或功能在前台展示的启用状态。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670381</data>
  <data key="d6"></data>
</node>
<node id="下架状态">
  <data key="d0">下架状态</data>
  <data key="d1">concept</data>
  <data key="d2">内容或功能在前台隐藏的禁用状态。</data>
  <data key="d3">chunk-1f797cabbc3ad11af3e5b3a149665e5c</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="业务规则">
  <data key="d0">业务规则</data>
  <data key="d1">concept</data>
  <data key="d2">业务规则定义了评论模块的操作限制，包括同一用户对同一商品一笔订单只能评论一次、评分为整数1~5默认5星、内容字符限制10~500字、可配置审核机制等。&lt;SEP&gt;业务规则是对各配置模块的约束条件说明，包括数量限制、状态校验、时间控制等。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec&lt;SEP&gt;chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="评论筛选">
  <data key="d0">评论筛选</data>
  <data key="d1">method</data>
  <data key="d2">评论筛选是帮助用户快速浏览特定类型评论的功能，支持按全部、有图、好评、中评、差评等维度筛选。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="评论排序">
  <data key="d0">评论排序</data>
  <data key="d1">method</data>
  <data key="d2">评论排序是调整评论显示顺序的功能，支持按最新优先和最多点赞两种方式排序。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="后台商品管理模块">
  <data key="d0">后台商品管理模块</data>
  <data key="d1">concept</data>
  <data key="d2">后台商品管理模块是为商品运营人员提供商品信息维护能力的系统模块，包括新增、编辑、上下架、删除商品等功能。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="商品列表查看">
  <data key="d0">商品列表查看</data>
  <data key="d1">method</data>
  <data key="d2">商品列表查看是后台商品管理的基础功能，支持分页搜索、筛选上下架状态，默认按创建时间倒序排序。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="新增商品">
  <data key="d0">新增商品</data>
  <data key="d1">method</data>
  <data key="d2">新增商品是后台商品管理功能，支持主图、详情图、规格等字段，用于创建新的商品信息。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670392</data>
  <data key="d6"></data>
</node>
<node id="编辑商品">
  <data key="d0">编辑商品</data>
  <data key="d1">method</data>
  <data key="d2">编辑商品是后台商品管理功能，包括修改标题、描述、分类、价格等商品信息。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="上下架商品">
  <data key="d0">上下架商品</data>
  <data key="d1">method</data>
  <data key="d2">上下架商品是后台商品管理功能，用于切换商品是否在前台展示。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="删除商品">
  <data key="d0">删除商品</data>
  <data key="d1">method</data>
  <data key="d2">删除商品是后台商品管理功能，采用逻辑删除方式，避免影响已有订单。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="权限控制">
  <data key="d0">权限控制</data>
  <data key="d1">concept</data>
  <data key="d2">权限控制是评论模块的安全机制，规定仅用户对已收货订单中的商品可评价。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="F5.2评论图片上传">
  <data key="d0">F5.2评论图片上传</data>
  <data key="d1">method</data>
  <data key="d2">F5.2评论图片上传是评论模块的子功能，允许用户为评论附带图片，每条评论最多上传5张，支持jpg/jpeg/png格式，单图最大2MB。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="F5.3评论展示">
  <data key="d0">F5.3评论展示</data>
  <data key="d1">method</data>
  <data key="d2">F5.3评论展示是商品详情页的功能，展示用户真实评价信息，包括评分、内容、图片、用户昵称等。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="F5.4评论筛选与排序">
  <data key="d0">F5.4评论筛选与排序</data>
  <data key="d1">method</data>
  <data key="d2">F5.4评论筛选与排序是评论模块的功能，支持按全部、有图、好评、中评、差评筛选，支持按最新优先和最多点赞排序。</data>
  <data key="d3">chunk-7ab6b016312276bd0784b4ea1e09d7ec</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="轮播图配置">
  <data key="d0">轮播图配置</data>
  <data key="d1">concept</data>
  <data key="d2">轮播图配置是用于管理首页轮播图片的模块，支持CDN加速展示图片、设置跳转链接、控制展示状态和排序权重等功能。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="推荐位类型">
  <data key="d0">推荐位类型</data>
  <data key="d1">data</data>
  <data key="d2">推荐位类型字段用于定义推荐位的类别，如首页顶部、首页中部、分类推荐等。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670404</data>
  <data key="d6"></data>
</node>
<node id="显示名称">
  <data key="d0">显示名称</data>
  <data key="d1">data</data>
  <data key="d2">显示名称字段用于设置推荐商品的展示名称，默认使用商品标题。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="是否固定展示">
  <data key="d0">是否固定展示</data>
  <data key="d1">data</data>
  <data key="d2">是否固定展示字段用于设置推荐商品是否锁定展示或随排序变化。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="排序">
  <data key="d0">排序</data>
  <data key="d1">data</data>
  <data key="d2">排序字段用于控制推荐位的展示顺序。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="公告内容">
  <data key="d0">公告内容</data>
  <data key="d1">data</data>
  <data key="d2">公告内容字段用于设置公告的具体文本内容，支持超链接或简单富文本格式。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="发布时间">
  <data key="d0">发布时间</data>
  <data key="d1">data</data>
  <data key="d2">发布时间字段用于设置公告的发布时间，格式为yyyy-MM-dd HH:mm:ss。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="权重">
  <data key="d0">权重</data>
  <data key="d1">data</data>
  <data key="d2">权重字段用于控制多条公告的展示顺序。</data>
