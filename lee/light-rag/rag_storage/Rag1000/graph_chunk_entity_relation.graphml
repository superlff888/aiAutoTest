  <data key="d5">1779670415</data>
  <data key="d6"></data>
</node>
<node id="定时上架">
  <data key="d0">定时上架</data>
  <data key="d1">concept</data>
  <data key="d2">定时上架表示内容在达到指定开始时间后自动生效为上架状态。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="定时下架">
  <data key="d0">定时下架</data>
  <data key="d1">concept</data>
  <data key="d2">定时下架表示内容在到达失效时间后自动隐藏为下架状态。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="内容型组件">
  <data key="d0">内容型组件</data>
  <data key="d1">concept</data>
  <data key="d2">内容型组件是可应用上下架控制的组件类型，包括轮播图、商品推荐位、公告栏等。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="image_url">
  <data key="d0">image_url</data>
  <data key="d1">data</data>
  <data key="d2">image_url是图片地址字段的数据类型标识，用于存储支持CDN加速的图片URL地址。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="string">
  <data key="d0">string</data>
  <data key="d1">data</data>
  <data key="d2">string是标题字段的数据类型标识，表示标题为字符串类型。</data>
