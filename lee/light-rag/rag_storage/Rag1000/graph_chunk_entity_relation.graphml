  <data key="d0">订单确认页</data>
  <data key="d1">content</data>
  <data key="d2">订单确认页是用户提交订单后可跳转的页面，用于确认订单信息并进行支付操作。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="支付页">
  <data key="d0">支付页</data>
  <data key="d1">content</data>
  <data key="d2">支付页是用户进行订单支付的页面，可调起支付系统完成支付流程。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="商品评价">
  <data key="d0">商品评价</data>
  <data key="d1">content</data>
  <data key="d2">商品评价是用户针对已完成订单的商品发表的评价内容。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="失效商品">
  <data key="d0">失效商品</data>
  <data key="d1">concept</data>
  <data key="d2">失效商品是指因下架或删除而无法正常购买结算的商品，需从购物车中剔除或标记。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="去结算">
  <data key="d0">去结算</data>
  <data key="d1">method</data>
  <data key="d2">去结算是用户完成购物车商品选择后点击的操作按钮，用于进入订单提交流程。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="已评价">
  <data key="d0">已评价</data>
  <data key="d1">concept</data>
  <data key="d2">已评价是订单的最终状态之一，表示用户已完成对商品的评价。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="支付成功页">
  <data key="d0">支付成功页</data>
  <data key="d1">content</data>
  <data key="d2">支付成功页是用户完成订单支付后跳转的页面，用于展示支付结果。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670194</data>
  <data key="d6"></data>
</node>
<node id="微信">
  <data key="d0">微信</data>
  <data key="d1">concept</data>
  <data key="d2">微信是支付系统预留接口支持的支付渠道之一。</data>
  <data key="d3">chunk-9a5ab321149976c4182afc52b340e847</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670207</data>
  <data key="d6"></data>
</node>
<node id="支付宝">
  <data key="d0">支付宝</data>
  <data key="d1">concept</data>
