  <data key="d0">编辑收货地址</data>
  <data key="d1">method</data>
  <data key="d2">编辑收货地址是用户收货地址管理功能的一部分，允许用户修改已有收货地址。</data>
  <data key="d3">chunk-7622d91dc7978a2d23cb1df61c4e819f</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670178</data>
  <data key="d6"></data>
</node>
<node id="删除收货地址">
  <data key="d0">删除收货地址</data>
  <data key="d1">method</data>
  <data key="d2">删除收货地址是用户收货地址管理功能的一部分，允许用户删除已有收货地址。</data>
  <data key="d3">chunk-7622d91dc7978a2d23cb1df61c4e819f</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670178</data>
  <data key="d6"></data>
