<node id="获取商品评论API">
  <data key="d0">获取商品评论API</data>
  <data key="d1">method</data>
  <data key="d2">获取商品评论API是用于查询特定商品_reviews的接口，路径为GET /api/products/{productId}/reviews。</data>
  <data key="d3">chunk-c6682f4c5dd06691e9a765b74339fddb</data>
