  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="url">
  <data key="d0">url</data>
  <data key="d1">data</data>
  <data key="d2">url是跳转链接字段的数据类型标识，用于指定活动页或商品页的链接地址。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="枚举">
  <data key="d0">枚举</data>
  <data key="d1">data</data>
  <data key="d2">枚举是状态字段的数据类型标识，表示状态值来自固定的选择集合。</data>
  <data key="d3">chunk-cbf34cedf85e135b8e68b8c9c48d8055</data>
  <data key="d4">需求说明书.md</data>
  <data key="d5">1779670428</data>
  <data key="d6"></data>
</node>
<node id="number">
  <data key="d0">number</data>
  <data key="d1">data</data>
  <data key="d2">number是排序权重字段的数据类型标识，表示排序权重为数值类型。</data>
