<node id="收藏记录">
  <data key="d0">收藏记录</data>
  <data key="d1">data</data>
  <data key="d2">收藏记录存储用户与商品的收藏关系，存在于数据库中。</data>
  <data key="d3">chunk-c502f8a340d6b25f0a1f38beb7ae5b21</data>
