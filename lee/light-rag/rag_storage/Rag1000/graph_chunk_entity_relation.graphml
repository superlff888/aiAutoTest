  <data key="d0">支付订单API</data>
  <data key="d1">method</data>
  <data key="d2">支付订单API是用于完成订单支付的接口，路径为POST /api/orders/{orderId}/pay。</data>
  <data key="d3">chunk-c6682f4c5dd06691e9a765b74339fddb</data>
  <data key="d4">电商系统API接口文档.md</data>
  <data key="d5">1779638199</data>
  <data key="d6"></data>
</node>
<node id="取消订单API">
  <data key="d0">取消订单API</data>
  <data key="d1">method</data>
  <data key="d2">取消订单API是用于取消未支付订单的接口，路径为PUT /api/orders/{orderId}/cancel。</data>
  <data key="d3">chunk-c6682f4c5dd06691e9a765b74339fddb</data>
  <data key="d4">电商系统API接口文档.md</data>
