        ],
        "test_data": {
            "userId": 123,
            "addressId": 1
        },
        "execute_step": [
            "创建地址A（系统自动设为默认地址）",
            "创建地址B（非默认地址）",
            "调用DELETE /api/users/123/addresses/1接口删除地址A",
            "调用GET /api/users/123/addresses查询地址列表"
        ],
        "expected_result": [
            "删除接口返回成功状态码",
            "地址A删除成功",
            "地址B自动被设为默认地址",
            "查询结果显示地址B的isDefault为true"
        ],
        "result": null,
        "review_result": "通过",
        "review_decs": "用例设计合理，覆盖删除默认地址后自动设默认的业务规则"
